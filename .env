# InfluxDB Configuration
INFLUX_URL=http://influxdb:8086
INFLUX_ORG=ukshati
INFLUX_BUCKET=energy
INFLUX_TOKEN=your_influxdb_token_here

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC=energy-meter

# Producer Configuration
PRODUCER_INTERVAL=1.0

# Spark Configuration
SPARK_MASTER=local[*]
SPARK_APP_NAME=EnergyCalculationEngine

# Asset Configuration
ASSET_ID=motor1
ASSET_NAME=Motor 1
ASSET_TYPE=3-Phase Motor
